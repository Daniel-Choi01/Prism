# Copy these into your Vercel project: Settings → Environment Variables.
# (For local dev with `vercel dev`, put real values in a .env file — never commit it.)

# --- Claude (Anthropic) — required for live reflections ---
# Get one at https://console.anthropic.com  (Settings → API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# --- Supabase — required to save/share reflections ---
# Supabase dashboard → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Use the SERVICE ROLE key (server-side only — NEVER ship this to the browser)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Supabase Auth (for login: Google + anonymous) ---
# The ANON / publishable key is PUBLIC and safe in the browser (RLS protects data).
# Served to the client via /api/config. Without it, the app runs in guest-only mode.
# Also enable providers in Supabase: Authentication → Providers → Anonymous (on),
# and Google (add Google OAuth client id/secret + your Vercel URL as a redirect).
SUPABASE_ANON_KEY=eyJ...
