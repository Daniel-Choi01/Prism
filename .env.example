# Copy these into your Vercel project: Settings → Environment Variables.
# (For local dev with `vercel dev`, put real values in a .env file — never commit it.)

# --- Claude (Anthropic) — required for live reflections ---
# Get one at https://console.anthropic.com  (Settings → API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# --- Supabase — required to save/share reflections ---
# Supabase dashboard → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Use the SERVICE ROLE key (server-side only — NEVER ship this to the browser)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Supabase Auth (for login: username/password + anonymous) ---
# The ANON / publishable key is PUBLIC and safe in the browser (RLS protects data).
# Served to the client via /api/config. Without it, the app runs in guest-only mode.
# In Supabase → Authentication → Providers:
#   • Email: ON, and turn OFF "Confirm email" (usernames map to synthetic emails,
#     so there's no inbox to confirm — required for username/password to work).
#   • Anonymous: ON (for the one-tap "Continue anonymously" option).
SUPABASE_ANON_KEY=eyJ...

# --- Cross-device cloud sync (optional, recommended once Auth is on) ---
# Run the "CLOUD SYNC" block in supabase/schema.sql to create the user_state
# table + Row-Level Security. Signed-in users then sync their private bundle
# (reflections, journal, check-ins) across devices; guests stay on-device only.
# No extra env vars are needed — the browser uses the public anon key under RLS.

# --- Sanity check after deploy ---
# Open https://YOUR-SITE.vercel.app/api/health — it reports which vars are present
# (booleans only, never their values). "ready": true means you're fully wired.
